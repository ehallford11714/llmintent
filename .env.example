# Copy to .env in the project root (never commit .env)
# cp .env.example .env

# PyPI (production)
TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-REPLACE_WITH_YOUR_TOKEN

# TestPyPI (optional — use scripts/publish.ps1 -TestPyPI)
# TWINE_REPOSITORY=testpypi
# TWINE_TESTPYPI_USERNAME=__token__
# TWINE_TESTPYPI_PASSWORD=pypi-REPLACE_WITH_TESTPYPI_TOKEN

# Hugging Face (optional — model downloads)
# HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN
